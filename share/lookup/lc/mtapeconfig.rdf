         xmlns:dcterms="http://purl.org/dc/terms/"
         xmlns:cc="http://creativecommons.org/ns#"
         xmlns:foaf="http://xmlns.com/foaf/0.1/">
   <madsrdf:MADSScheme xmlns:madsrdf="http://www.loc.gov/mads/rdf/v1#"
                       rdf:about="http://id.loc.gov/vocabulary/mtapeconfig">
      <rdfs:label xml:lang="en">Tape Configuration</rdfs:label>
      <rdfs:comment xml:lang="en" rdf:parseType="Literal"/>
      <madsrdf:definitionNote xml:lang="en">Number of tracks on a tape</madsrdf:definitionNote>
      <madsrdf:hasMADSSchemeMember>
         <madsrdf:Authority rdf:about="http://id.loc.gov/vocabulary/mtapeconfig/full">
            <madsrdf:authoritativeLabel>Full track</madsrdf:authoritativeLabel>
            <madsrdf:code>full</madsrdf:code>
         </madsrdf:Authority>
      </madsrdf:hasMADSSchemeMember>
      <madsrdf:hasMADSSchemeMember>
         <madsrdf:Authority rdf:about="http://id.loc.gov/vocabulary/mtapeconfig/half">
            <madsrdf:authoritativeLabel>Half track</madsrdf:authoritativeLabel>
            <madsrdf:code>half</madsrdf:code>
         </madsrdf:Authority>
      </madsrdf:hasMADSSchemeMember>
      <madsrdf:hasMADSSchemeMember>
         <madsrdf:Authority rdf:about="http://id.loc.gov/vocabulary/mtapeconfig/quarter">
            <madsrdf:authoritativeLabel>Quarter track</madsrdf:authoritativeLabel>
            <madsrdf:code>quarter</madsrdf:code>
         </madsrdf:Authority>
      </madsrdf:hasMADSSchemeMember>
      <madsrdf:hasMADSSchemeMember>
         <madsrdf:Authority rdf:about="http://id.loc.gov/vocabulary/mtapeconfig/8">
            <madsrdf:authoritativeLabel>8 track</madsrdf:authoritativeLabel>
            <madsrdf:code>8</madsrdf:code>
         </madsrdf:Authority>
      </madsrdf:hasMADSSchemeMember>
      <madsrdf:hasMADSSchemeMember>
         <madsrdf:Authority rdf:about="http://id.loc.gov/vocabulary/mtapeconfig/12">
            <madsrdf:authoritativeLabel>12 track</madsrdf:authoritativeLabel>
            <madsrdf:code>12</madsrdf:code>
         </madsrdf:Authority>
      </madsrdf:hasMADSSchemeMember>
      <madsrdf:hasMADSSchemeMember>
         <madsrdf:Authority rdf:about="http://id.loc.gov/vocabulary/mtapeconfig/16">
            <madsrdf:authoritativeLabel>16 track</madsrdf:authoritativeLabel>
            <madsrdf:code>16</madsrdf:code>
         </madsrdf:Authority>
      </madsrdf:hasMADSSchemeMember>
      <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#ConceptScheme"/>
      <skos:definition xml:lang="en">Number of tracks on a tape</skos:definition>
   </madsrdf:MADSScheme>
</rdf:RDF>
